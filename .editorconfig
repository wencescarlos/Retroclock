# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# C++ source files
[*.{cpp,cc,cxx,h,hpp,hxx}]
indent_style = space
indent_size = 4
max_line_length = 100

# C/C++ header files
[*.h]
indent_style = space
indent_size = 4

# Makefiles
[Makefile]
indent_style = tab

# Python files
[*.py]
indent_style = space
indent_size = 4

# YAML files (platformio.ini comments, workflows)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Ini/Config files
[*.ini]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf
